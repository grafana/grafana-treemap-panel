{
  "name": "marcusolsson-treemap-panel",
  "version": "2.1.1",
  "description": "A panel plugin for Grafana to visualize treemaps",
  "keywords": [
    "grafana",
    "treemap"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --coverage --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "e2e": "docker compose --profile playwright up --abort-on-container-exit",
    "e2e:update-screenshots": "docker compose --profile playwright-update-screenshots up --abort-on-container-exit",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "coverage": "yarn coverage:clean && yarn e2e && yarn test:ci && yarn coverage:merge-reports",
    "coverage:clean": "rm -rf coverage && rm -rf coverage-merged",
    "coverage:merge-reports": "node scripts/merge-coverage.js"
  },
  "homepage": "https://grafana.com/plugins/marcusolsson-treemap-panel",
  "bugs": "https://github.com/grafana/grafana-treemap-panel/issues",
  "repository": "github:grafana/grafana-treemap-panel",
  "author": {
    "name": "Grafana Labs",
    "url": "https://grafana.com"
  },
  "devDependencies": {
    "@grafana/eslint-config": "8.0.0",
    "@grafana/plugin-e2e": "2.0.2",
    "@grafana/tsconfig": "2.0.0",
    "@playwright/test": "1.55.0",
    "@stylistic/eslint-plugin-ts": "2.13.0",
    "@swc/core": "1.11.24",
    "@swc/helpers": "0.5.17",
    "@swc/jest": "0.2.38",
    "@testing-library/jest-dom": "6.1.4",
    "@testing-library/react": "14.0.0",
    "@types/d3": "5.16.7",
    "@types/jest": "29.5.14",
    "@types/node": "20.17.46",
    "@types/testing-library__jest-dom": "5.14.8",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "6.11.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.0",
    "eslint-plugin-deprecation": "2.0.0",
    "eslint-plugin-jsdoc": "46.10.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-webpack-plugin": "4.2.0",
    "fork-ts-checker-webpack-plugin": "8.0.0",
    "glob": "10.5.0",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-monocart-coverage": "1.1.1",
    "monocart-reporter": "2.9.21",
    "prettier": "2.8.8",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.63.2",
    "sass-loader": "13.3.1",
    "semver": "7.7.2",
    "style-loader": "3.3.3",
    "swc-loader": "0.2.6",
    "terser-webpack-plugin": "5.6.1",
    "ts-node": "10.9.2",
    "typescript": "5.5.4",
    "webpack": "5.107.2",
    "webpack-cli": "5.1.4",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "^11.5.3",
    "@grafana/runtime": "^11.5.3",
    "@grafana/schema": "^11.5.3",
    "@grafana/ui": "^11.5.3",
    "monocart-coverage-reports": "^2.12.6",
    "rb-tippyjs-react": "^4.3.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
